# Copy to .env in this directory (never commit .env)
# Or set these in repo-root .env.local — download.ts loads both.

# Required — bulk zip downloads return 403 without this header
OPENSTATES_PLURAL_API_KEY=

# Optional alias (pyopenstates compatibility)
# OPENSTATES_API_KEY=

# Where to store downloaded zips and people CSV (default: ../../data/openstates)
# OPENSTATES_DATA_DIR=
